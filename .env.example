# MongoDB connection string (used to persist seen contests across runs)
# Get this from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your-bot-token-here

# The ID of the channel where contest alerts will be posted
# Right-click the channel in Discord → Copy Channel ID
DISCORD_CHANNEL_ID=123456789012345678

# The ID of the role to @mention when a new contest or reminder fires
# Right-click the role in Server Settings → Copy Role ID
# Set to 0 or leave blank to disable role mentions
DISCORD_ROLE_ID=0

# How often (in minutes) to check all platforms for new contests
CHECK_INTERVAL_MINUTES=15

# Comma-separated list of how many minutes BEFORE a contest starts to send reminders
# e.g. "60,10" → one reminder 1 hour before, one reminder 10 minutes before
REMIND_BEFORE_MINUTES=60,10

# Your CLIST API key (get from https://clist.by/api/v4/)
CLIST_API_KEY=your-clist-api-key-here

# Your CLIST username (get from https://clist.by/api/v4/)
CLIST_USERNAME=your-clist-username-here